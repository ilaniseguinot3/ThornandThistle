  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85988e2c37ff48e47ad02f21e878334a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::RecipeBook
  recipes:
  - recipeName: Lacerations
    description: "These are among the easiest to identify. They are equally acquired
      through diving into danger and mundane misadventure. Look for slashed skin
      and heavy bleeding. \n\nTreatment: Salve\r\n"
    ingredients:
    - ingredientName: Calendula
      ingredientSprite: {fileID: 21300000, guid: 739d12376dd651647aeb6be969a55d31, type: 3}
    - ingredientName: Comfrey
      ingredientSprite: {fileID: 21300000, guid: 2ea4d495ec002f14790d36cc351398b2, type: 3}
    - ingredientName: Plaintain
      ingredientSprite: {fileID: 21300000, guid: 529fc049d783ef94fa31a04dee747e05, type: 3}
    - ingredientName: Salve Tin
      ingredientSprite: {fileID: 21300000, guid: 27c6e8aaa2bebda4cb0ed5edd39d04e9, type: 3}
  - recipeName: Tincture
    description: 'By far the most deadly, and must be treated quickly. Symptoms include
      malaise of the mind, inflammation, and bowel upset.


      Treatment: Tincture'
    ingredients:
    - ingredientName: milk thistle
      ingredientSprite: {fileID: 21300000, guid: 577b468367ed7834989d72e670d58b7e, type: 3}
    - ingredientName: tincture bottle
      ingredientSprite: {fileID: 21300000, guid: 5789263caef06ab4b85940dbb52439f6, type: 3}
  - recipeName: Poultice
    description: "Similar in acquisition to the laceration, yet more often the product
      of encounters with nature. Look out for tiny, clustered bumps and reports of
      itching. \n\nTreatment: Poultice\r\n"
    ingredients:
    - ingredientName: echinacea
      ingredientSprite: {fileID: 21300000, guid: 02ca682531b0b0b46adec35a3c3d1d73, type: 3}
    - ingredientName: 'white oak bark '
      ingredientSprite: {fileID: 21300000, guid: 2d635a76608b6a246979e67dd88bbe88, type: 3}
    - ingredientName: comfrey leaf
      ingredientSprite: {fileID: 21300000, guid: 2ea4d495ec002f14790d36cc351398b2, type: 3}
    - ingredientName: poultice tin
      ingredientSprite: {fileID: 21300000, guid: 39c74cc4554426a4d9a9ca6f34710e76, type: 3}
  recipeTitleText: {fileID: 8860923053527852202}
  descriptionText: {fileID: 2003550598}
